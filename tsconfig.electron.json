{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2023"
    ],
    "types": [
      "node",
      "electron"
    ],
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "outDir": "dist-electron",
    "rootDir": "desktop",
    "noEmit": false
  },
  "include": [
    "desktop/**/*.ts"
  ],
  "exclude": [
    "desktop/**/*.test.ts"
  ]
}
